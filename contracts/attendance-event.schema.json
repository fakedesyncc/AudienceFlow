{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audienceflow.local/contracts/attendance-event.schema.json",
  "title": "AttendanceEvent",
  "type": "object",
  "required": ["room_id", "ts", "count", "confidence", "worker_id"],
  "additionalProperties": false,
  "properties": {
    "room_id": {
      "type": "integer",
      "minimum": 1
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "count": {
      "type": "integer",
      "minimum": 0
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "worker_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128
    }
  }
}
